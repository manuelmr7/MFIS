% 3. ESPECIFICACIÓN DE INVARIANTES OCL
% ==========================================
\section{Especificación Formal de Restricciones (Invariantes)}

Esta sección documenta la formalización semántica de las reglas de negocio, divididas entre los requisitos obligatorios del enunciado y las ampliaciones creativas.

\subsection{Restricciones Obligatorias (Reglas Base)}

\textbf{1. Cierre de seguridad infantil:} Si en el grupo de pasajeros hay un niño con una edad inferior a 12 años, el vehículo debe activar obligatoriamente el cierre de seguridad.
\begin{lstlisting}
context vAutonomo inv cierreInfantil:
    self.pasajeros->exists(p | p.edad < 12) implies self.cierreSeguridad = true
\end{lstlisting}

\textbf{2. Sensores en conducción autónoma:} Un vehículo en modo autónomo debe tener todos sus sensores críticos en estado operativo.
\begin{lstlisting}
context vAutonomo inv sensoresCriticos:
    self.modo = ModoConduccion::Autonomo implies 
    self.sensores->select(s | s.esCritico)->forAll(s | s.estado = EstadoSensor::Operativo)
\end{lstlisting}

\textbf{3. Mantenimiento por kilometraje:} Cuando un vehículo supera los 5.000 km totales pasa a mantenimiento y se retira de la circulación hasta que pase de nuevo al estado operativo.
\begin{lstlisting}
context vAutonomo inv kmMantenimiento:
    self.kilometrajeTot > 5000 implies self.estado = EstadoVehiculo::Mantenimiento
\end{lstlisting}

\textbf{4. Control de aforo:} Un vehículo no puede arrancar si el número de pasajeros es mayor que el número de asientos disponibles.
\begin{lstlisting}
context vAutonomo inv capacidadAsientos:
    self.velocidad > 0 implies self.pasajeros->size() <= self.numAsientos
\end{lstlisting}

\textbf{5. Capacidad máxima de zonas:} Ninguna zona puede albergar más vehículos que los que permite su capacidad máxima.
\begin{lstlisting}
context Zona inv capacidadVehiculos:
    self.vehiculos->size() <= self.capacidadMax
\end{lstlisting}

\textbf{6. Tiempo de espera de rutas:} El tiempo total de espera no puede superar los 30 minutos.
\begin{lstlisting}
context Ruta inv tiempoEsperaMax:
    self.tiempoEspera <= 30
\end{lstlisting}

\textbf{7. Logística de equipaje:} Si un pasajero lleva equipaje pesado, el vehículo debe tener el maletero disponible.
\begin{lstlisting}
context vAutonomo inv maleteroEquipaje:
    self.pasajeros->exists(p | p.tieneEquipajePesado) implies self.maleteroDisponible = true
\end{lstlisting}

\textbf{8. Velocidad peatonal:} En las zonas de peatones, la velocidad máxima permitida no supera los 20 kms/hora.
\begin{lstlisting}
context vAutonomo inv limitePeatones:
    self.zona.tipo = TipoZona::Peatonal implies self.velocidad <= 20
\end{lstlisting}

\textbf{9. Protocolo de batería crítica:} Si la batería del vehículo está por debajo del 10\%, el vehículo no debe aceptar pasajeros e ir a la zona más cerca de carga.
\begin{lstlisting}
context vAutonomo inv bateriaBaja:
    self.nivelBateria < 10 implies (self.pasajeros->isEmpty() and self.zona.tipo = TipoZona::Carga)
\end{lstlisting}

\textbf{10. Jerarquía de tarifas:} La tarifa de un trayecto para un pasajero "estandar" no puede ser inferior a la de un pasajero "oro".
\begin{lstlisting}
context Pasajero inv tarifas:
    (self.tipo = TipoPasajero::Estandar and Pasajero.allInstances()->exists(p|p.tipo = TipoPasajero::Oro)) 
    implies self.tarifa >= Pasajero.allInstances()->select(p|p.tipo = TipoPasajero::Oro)->any(true).tarifa
\end{lstlisting}

\textbf{11. Protocolo de emergencias:} Cuando una zona cambia al estado de "emergencia", el vehículo cambia a modo manual.
\begin{lstlisting}
context vAutonomo inv zonaEmergencia:
    self.zona.tipo = TipoZona::Emergencia implies self.modo = ModoConduccion::Manual
\end{lstlisting}

\textbf{12. Restricción de rutas prioritarias:} Las rutas prioritarias solo pueden asignarse a vehículos con conducción autónoma.
\begin{lstlisting}
context Ruta inv rutaPrioritaria:
    self.esPrioritaria implies self.vehiculo.modo = ModoConduccion::Autonomo
\end{lstlisting}

\subsection{Restricciones Creativas y Mejoras del Sistema}
Para asegurar la fiabilidad del modelo y añadir valor real, se han formalizado reglas de negocio avanzadas:

\textbf{13. Mantenimiento seguro:} Un vehículo en taller no puede contener pasajeros.
\begin{lstlisting}
context vAutonomo inv mantenimientoSinPasajeros:
    self.estado = EstadoVehiculo::Mantenimiento implies self.pasajeros->isEmpty()
\end{lstlisting}

\textbf{14. Redundancia de alertas:} El Centro de Control debe reaccionar activando su alerta si una zona entra en emergencia.
\begin{lstlisting}
context CentroControl inv alertaEmergencia:
    self.zonas->exists(z | z.tipo = TipoZona::Emergencia) implies self.estadoAlerta = true
\end{lstlisting}

\textbf{15. Físicas de recarga:} Un vehículo no puede estar en movimiento dentro de una estación de carga.
\begin{lstlisting}
context vAutonomo inv cargaParado:
    self.zona.tipo = TipoZona::Carga implies self.velocidad = 0
\end{lstlisting}

\textbf{16. Límite de vida útil de batería (Mejora solicitada):} Para evitar la degradación de los acumuladores de litio, la carga se capa por software al 85\%.
\begin{lstlisting}
context vAutonomo inv limiteCargaMax:
    self.nivelBateria <= 85
\end{lstlisting}

\textbf{17. Automatización de disponibilidad:} Al alcanzar el tope seguro del 85\%, el vehículo entra en servicio automáticamente.
\begin{lstlisting}
context vAutonomo inv disponibleAlCargar:
    self.nivelBateria = 85 implies self.disponible = true
\end{lstlisting}

